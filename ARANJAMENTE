#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>

int n, v[100], p, cnt = 0;

int valid(int k)
{
    int i;
    for (i = 0; i < k; i++)
        if (v[i] == v[k])
            return 0;
    return 1;
}

void afisare(int k)
{
    int i;
    for (i = 0; i <= k; i++)
        printf("%d ", v[i]);

    printf("\n");
    cnt++;
}

void BK(int k)
{

    for (int i = 1; i <= n; i++)
    {
        v[k] = i;

        if (valid(k))
        {
            if (k==p-1)
            {
                afisare(k);
            }
            else
            {
                BK(k + 1);
            }
        }
    }
}

int main()
{
    printf("Introduceti n: ");
    scanf("%d", &n);

    printf("Introduceti p: ");
    scanf("%d", &p);

    BK(0);

    printf("Exista %d solutii", cnt);

    return 0;
}
