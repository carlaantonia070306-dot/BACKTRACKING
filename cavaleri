#define _CRT_SECURE_NO_WARNINGS
#include <stdio.h>
#include <math.h>
#include <stdlib.h>

int n, v[100], cnt = 0;

int valid(int k)
{
    for (int i = 0; i < k; i++)
        if (v[i] == v[k])
            return 0;

    if (k > 0)
    {
        if (abs(v[k] - v[k - 1]) != 2 && abs(v[k] - v[k - 1]) != 3)
            return 0;
    }

    if (k == n - 1)
    {
        if (abs(v[n - 1] - v[0]) != 2 && abs(v[n - 1] - v[0]) != 3)
            return 0;
    }

    return 1;
}

void afisare()
{
    cnt++;
    printf("Solutia %d: ", cnt);

    for (int i = 0; i < n; i++)
        printf("%d ", v[i]);

    printf("\n");
}

void BK(int k)
{
    for (int i = 1; i <= n; i++)
    {
        v[k] = i;

        if (valid(k))
        {
            if (k == n - 1)
                afisare();
            else
                BK(k + 1);
        }
    }
}

int main()
{
    printf("n = ");
    scanf("%d", &n);

    BK(0);

    printf("Total solutii: %d\n", cnt);

    return 0;
}
